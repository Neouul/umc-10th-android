<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:context=".MainActivity">

    <!--  메인 텍스트 구역  -->
    <TextView
        android:id="@+id/tv_main1"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="오늘 하루는 어땠나요?"
        android:textSize="30sp"
        android:fontFamily="@font/gangwon_edu_hyeonok_teacher"
        android:layout_marginTop="100dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_main2"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="감정우표를 선택해주세요"
        android:textSize="22sp"
        android:fontFamily="@font/gangwon_edu_hyeonok_teacher"
        app:layout_constraintTop_toBottomOf="@id/tv_main1"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_main3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="선택한 감정우표를 기반으로 맞춤형 질문이 배달됩니다"
        android:textSize="8sp"
        android:layout_marginTop="14dp"
        app:layout_constraintTop_toBottomOf="@id/tv_main2"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <!--  우표 선택 구역  -->
    <ImageView
        android:id="@+id/iv_happy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="happy icon"
        android:src="@drawable/ic_happy"
        android:layout_marginTop="27dp"
        app:layout_constraintTop_toBottomOf="@id/tv_main3"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_happy"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="더없이 행복한 하루였어요"
        android:textSize="18sp"
        android:fontFamily="@font/gangwon_edu_hyeonok_teacher"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/iv_happy"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <ImageView
        android:id="@+id/iv_exciting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="exciting icon"
        android:src="@drawable/ic_exciting"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_happy"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_exciting"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="들뜨고 흥분돼요"
        android:textSize="18sp"
        android:fontFamily="@font/gangwon_edu_hyeonok_teacher"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/iv_exciting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <ImageView
        android:id="@+id/iv_soso"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="soso icon"
        android:src="@drawable/ic_soso"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_exciting"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_soso"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="평범한 하루였어요"
        android:textSize="18sp"
        android:fontFamily="@font/gangwon_edu_hyeonok_teacher"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/iv_soso"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <ImageView
        android:id="@+id/iv_unrest"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="unrest icon"
        android:src="@drawable/ic_unrest"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_soso"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_unrest"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="생각이 많아지고 불안해요"
        android:textSize="18sp"
        android:fontFamily="@font/gangwon_edu_hyeonok_teacher"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/iv_unrest"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />


    <ImageView
        android:id="@+id/iv_angry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="angry icon"
        android:src="@drawable/ic_angry"
        android:layout_marginTop="20dp"
        app:layout_constraintTop_toBottomOf="@id/tv_unrest"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <TextView
        android:id="@+id/tv_angry"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="부글부글 화가 나요"
        android:textSize="18sp"
        android:fontFamily="@font/gangwon_edu_hyeonok_teacher"
        android:layout_marginTop="6dp"
        app:layout_constraintTop_toBottomOf="@id/iv_angry"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>